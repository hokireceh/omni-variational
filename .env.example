# ============================================================
# Variational Grid Bot — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# [WAJIB] Private key wallet kamu (64 karakter hex, dengan atau tanpa 0x)
WALLET_PRIVATE_KEY=your_private_key_here

# [WAJIB] VR_TOKEN dari browser (berlaku 7 hari)
# Cara ambil: Login ke omni.variational.io →
#   DevTools (F12) → Application → Cookies → vr-token
VR_TOKEN=eyJ0eXAiOiJKV1Qi...

# [Opsional] Alamat wallet (otomatis dari WALLET_PRIVATE_KEY jika tidak diset)
# WALLET_ADDRESS=0x...

# [Server] Port untuk api-server (default: 8080)
PORT=8080
